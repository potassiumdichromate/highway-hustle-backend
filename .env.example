# MongoDB Configuration
MONGO_URI=localhost:27017
# Server Configuration
PORT=5000
NODE_ENV=production

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=
# Optional: Rate Limiting (if you add it later)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Browser JWT auto-login
BROWSER_JWT_SECRET=replace-with-browser-jwt-secret
BROWSER_JWT_EXPIRES_IN=2h

# Cloudflare Workers AI (leaderboard comment generation)
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
# CF_LLM_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
# CF_TIMEOUT_MS=6000

# 0G Compute Inference
ZEROG_API_KEY=<api-key>
ZEROG_BASE_URL=<base-url>
ZEROG_MODEL=<model>
ZEROG_TIMEOUT_MS=<timeout-ms>
# Leaderboard commentary path (primary 0G, Cloudflare fallback)
ZEROG_LEADERBOARD_MODEL=<model>
ZEROG_LEADERBOARD_MAX_TOKENS=<max-tokens>
ZEROG_LEADERBOARD_TIMEOUT_MS=<timeout-ms>

# 0G EVM network defaults shared by all blockchain services
ZEROG_RPC_URL=<rpc-url>
ZEROG_CHAIN_ID=<chain-id>
